{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "outDir": "dist/main",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": ["src/frontend/desktop/**/*", "src/backend/**/*", "src/shared/**/*"],
  "exclude": ["node_modules"]
}
