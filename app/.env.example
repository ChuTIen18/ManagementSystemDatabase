# Environment variables
NODE_ENV=development

# API Server
API_PORT=3001
API_HOST=localhost

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=coffee_shop_db

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# App Settings
APP_NAME=Coffee Shop Management
APP_VERSION=1.0.0

# Logging
LOG_LEVEL=debug
